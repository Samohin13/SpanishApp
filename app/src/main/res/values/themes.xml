<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SpanishApp" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash Screen Theme (SplashScreen API, Android 12+) -->
    <style name="Theme.SpanishApp.Splash" parent="Theme.SplashScreen">
        <!-- Цвет фона сплеш-экрана -->
        <item name="windowSplashScreenBackground">#FF5722</item>
        <!-- Иконка в центре (adaptive icon) -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Тема которая применяется после скрытия сплеша -->
        <item name="postSplashScreenTheme">@style/Theme.SpanishApp</item>
    </style>

    <!-- Theme for Image Cropper Activity -->
    <style name="Theme.App.ImageCropper" parent="Theme.AppCompat.Light.DarkActionBar" />

</resources>
